# Copy this file to .env and fill in your values
# cp .env.example .env

# Admin login credentials
ADMIN_USER=admin
ADMIN_PASS=change-me-to-a-strong-password

# JWT secret — generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-string

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://sydneyblooms:yourpassword@localhost:5432/sydneyblooms

# Server port (optional, defaults to 3000)
PORT=3000
